#include <xc.h>       // Main XC8 header for PIC microcontrollers
#include <stdint.h>   // Standard integer types like uint8_t, uint16_t, uint32_t

// Define oscillator frequency used by __delay_ms() and __delay_us()
#define _XTAL_FREQ  20000000UL

// ===================== CONFIGURATION BITS =====================
// These settings configure the PIC hardware behavior before the program starts.
#pragma config FOSC  = HS     // High-speed crystal oscillator
#pragma config WDTE  = OFF    // Watchdog Timer disabled
#pragma config PWRTE = ON     // Power-up Timer enabled
#pragma config BOREN = ON     // Brown-out Reset enabled
#pragma config LVP   = OFF    // Low-voltage programming disabled
#pragma config CPD   = OFF    // Data EEPROM code protection disabled
#pragma config WRT   = OFF    // Flash program memory write protection disabled
#pragma config CP    = OFF    // Code protection disabled

// ===================== INPUT MASKS =====================
// These masks are used to read buttons and gas sensor from PORTA.
#define BTN_START_MASK  0x01   // RA0: Start button
#define BTN_PAUSE_MASK  0x02   // RA1: Pause button
#define GAS_MASK        0x08   // RA3: Gas sensor input
#define BTN_RESET_MASK  0x10   // RA4: Reset button
#define BTN_MODE_MASK   0x20   // RA5: Mode button

// ===================== DHT22 PIN =====================
// DHT22 data pin is connected to RA2.
#define DHT_PIN  PORTAbits.RA2
#define DHT_DIR  TRISAbits.TRISA2

// ===================== LCD PINS =====================
// LCD is used in 4-bit mode on PORTC.
#define LCD_RS  PORTCbits.RC0
#define LCD_EN  PORTCbits.RC1
#define LCD_D4  PORTCbits.RC2
#define LCD_D5  PORTCbits.RC3
#define LCD_D6  PORTCbits.RC4
#define LCD_D7  PORTCbits.RC5

// ===================== STATUS LEDS =====================
// Three status LEDs connected to PORTE.
#define LED_GREEN   PORTEbits.RE0
#define LED_YELLOW  PORTEbits.RE1
#define LED_RED     PORTEbits.RE2

// ===================== BARGRAPH =====================
// First two bargraph LEDs are on RC6 and RC7.
// Remaining LEDs are controlled by PORTD.
#define BAR_SEG0    PORTCbits.RC6
#define BAR_SEG1    PORTCbits.RC7

// ===================== TIMING CONSTANTS =====================
// These constants control delays, refresh times, debounce, and long press timing.
#define RESET_HOLD_MS         3000UL
#define DHT_REFRESH_MS        2500UL
#define DEBOUNCE_MS             40UL
#define LONGPRESS_LOCK_MS     1200UL
#define LONGPRESS_SCREEN_MS   2000UL
#define LCD_REFRESH_MS         200UL
#define FLASH_MSG_MS_SHORT     500UL
#define FLASH_MSG_MS_MEDIUM    700UL
#define FLASH_MSG_MS_LONG      900UL

// ===================== SYSTEM STATES =====================
// Main operating states of the smart oven.
typedef enum {
    ST_SETTING = 0,     // User enters time
    ST_RUNNING,         // Timer is counting down
    ST_PAUSED,          // Timer is paused
    ST_FINISHED,        // Timer finished
    ST_EMERGENCY        // Gas emergency detected
} state_t;

// ===================== LCD SCREENS =====================
// Different display pages shown on the LCD.
typedef enum {
    SCR_MAIN = 0,       // Time and state screen
    SCR_TEMP,           // Temperature and humidity screen
    SCR_SAFETY,         // Gas and alarm screen
    SCR_SYSTEM,         // Lock and system status screen
    SCR_COUNT           // Number of screens
} screen_t;

// ===================== BUTTON STRUCTURE =====================
// Stores button debounce and edge detection information.
typedef struct {
    uint8_t  stable;        // Stable debounced value
    uint8_t  last_raw;      // Last raw reading
    uint32_t last_change;   // Time when raw value changed
    uint8_t  fired;         // Prevents repeated triggering while held
} btn_t;

// ===================== KEYPAD STATE MACHINE =====================
// Used to detect normal key presses and long presses.
typedef enum {
    KSM_IDLE = 0,       // No key pressed
    KSM_DEBOUNCE,       // Waiting for stable key press
    KSM_HELD,           // Key is being held
    KSM_RELEASE_WAIT    // Long press detected, wait for release
} ksm_t;

// ===================== GLOBAL TIMER VARIABLES =====================
// Updated by Timer0 interrupt.
static volatile uint16_t g_subsec = 0;
static volatile uint32_t g_now_ms = 0;

// ===================== GLOBAL SYSTEM VARIABLES =====================
static volatile state_t  g_state  = ST_SETTING;  // Current oven state
static screen_t g_screen = SCR_MAIN;             // Current LCD screen
static volatile uint16_t g_remain = 0;           // Remaining time in seconds
static uint16_t g_total = 0;                     // Total entered time in seconds
static uint8_t g_lock = 0;                       // Child lock flag

// ===================== TIME ENTRY VARIABLES =====================
// Used to enter MMSS time from keypad.
static uint8_t g_mm = 0;
static uint8_t g_ss = 0;
static uint8_t g_entry_pos = 0;

// ===================== DHT22 VARIABLES =====================
static uint8_t  g_temp = 0;       // Temperature value
static uint8_t  g_hum  = 0;       // Humidity value
static uint8_t  g_dht_ok = 0;     // DHT reading status
static uint32_t g_dht_last = 0;   // Last DHT read time

// ===================== EVENT TIMESTAMPS =====================
static uint32_t g_finish_ts = 0;  // Time when countdown finished
static uint32_t g_emerg_ts = 0;   // Time when emergency started

// ===================== RESET HOLD VARIABLES =====================
// Used during emergency reset hold.
static uint32_t g_reset_hold_start = 0;
static uint8_t  g_reset_holding = 0;

// ===================== BUZZER FLAG =====================
static volatile uint8_t g_buzz = 0;

// ===================== BUTTON OBJECTS =====================
// Initial stable state is 1 because buttons are active-low.
static btn_t g_b_start = {1, 1, 0, 0};
static btn_t g_b_pause = {1, 1, 0, 0};
static btn_t g_b_reset = {1, 1, 0, 0};
static btn_t g_b_mode  = {1, 1, 0, 0};

// ===================== KEYPAD VARIABLES =====================
static ksm_t g_ksm = KSM_IDLE;
static uint32_t g_ksm_start_ms = 0;
static uint8_t g_ksm_row = 0;
static uint8_t g_ksm_col = 0;
static char g_pending_key = 0;
static uint8_t g_pending_long = 0;

// Flash message end time
static uint32_t g_flash_until = 0;

// Keypad layout: 4 rows x 3 columns
static const char keymap[4][3] = {
    {'1','2','3'},
    {'4','5','6'},
    {'7','8','9'},
    {'*','0','#'}
};

